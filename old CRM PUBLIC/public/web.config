<configuration>
  <system.webServer>
    <httpErrors errorMode="Detailed" />
    
    <rewrite>
      <rules>
        <!-- Serve static files directly -->
        <rule name="Static Files" stopProcessing="true">
          <match url="\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot|json|pb)$" />
          <action type="None" />
        </rule>

        <!-- Handle PHP files - ensure they're processed by PHP handler -->
        <rule name="PHP Files" stopProcessing="false">
          <match url="\.php$" />
          <action type="None" />
        </rule>

        <!-- Specific loginEmp route -->
        <rule name="Login API" stopProcessing="true">
          <match url="^api/loginEmp$" />
          <action type="Rewrite" url="index.php" />
        </rule>

        <!-- General API routes -->
        <rule name="Laravel API" stopProcessing="true">
          <match url="^api/.*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php" />
        </rule>

        <!-- All other routes serve React's index.html -->
        <rule name="React Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
	    <add input="{REQUEST_URI}" pattern="^/(api|storage)" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
      </rules>
    </rewrite>
        <staticContent>
            <mimeMap fileExtension=".pb" mimeType="application/octet-stream" />
        </staticContent>
  </system.webServer>
</configuration>